    src="https://cdn.apigateway.co/webchat-client..prod/sdk.js"
    data-widget-id="3d4868c8-fbc4-11f0-b22f-624d8abf8f93"
    defer
  ></script>

  <script>
    function initPage() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      }, { threshold: 0.12 });

      document.querySelectorAll('.fade-in-section').forEach((section) => {
        observer.observe(section);
      });

      const locationsField = document.getElementById('locations');
      const monthlyCostField = document.getElementById('monthlyCost');

      if (locationsField && monthlyCostField) {
        locationsField.addEventListener('input', () => {
          const locations = parseInt(locationsField.value, 10) || 0;
          monthlyCostField.value = getSuggestedPrice(locations);
        });
      }
    }

    function getSuggestedPrice(locations) {
      if (locations >= 1 && locations <= 10) return 499;
      if (locations >= 11 && locations <= 25) return 429;
      if (locations >= 26 && locations <= 50) return 379;
      if (locations >= 51) return 0;
      return 429;
    }

    function formatCurrency(value) {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
      }).format(value);
    }

    function calculateROI() {
      const locations = parseFloat(document.getElementById('locations').value) || 0;
      const monthlyLeads = parseFloat(document.getElementById('monthlyLeads').value) || 0;
      const missedLeadPct = (parseFloat(document.getElementById('missedLeadPct').value) || 0) / 100;
      const recoveryPct = (parseFloat(document.getElementById('recoveryPct').value) || 0) / 100;
      const closeRate = (parseFloat(document.getElementById('closeRate').value) || 0) / 100;
      const avgRevenue = parseFloat(document.getElementById('avgRevenue').value) || 0;
      const hoursSaved = parseFloat(document.getElementById('hoursSaved').value) || 0;
      const hourlyValue = parseFloat(document.getElementById('hourlyValue').value) || 0;
      const monthlyCost = parseFloat(document.getElementById('monthlyCost').value) || 0;

      const totalMissedLeads = locations * monthlyLeads * missedLeadPct;
      const recoveredLeads = totalMissedLeads * recoveryPct;
      const newCustomers = recoveredLeads * closeRate;
      const addedRevenue = newCustomers * avgRevenue;
      const savedValue = locations * hoursSaved * hourlyValue;
      const totalValue = addedRevenue + savedValue;
      const totalPlatformCost = locations * monthlyCost;
      const netGain = totalValue - totalPlatformCost;

      let roiPct = 0;
      if (totalPlatformCost > 0) {
        roiPct = (netGain / totalPlatformCost) * 100;
      }

      let paybackText = 'Custom quote tier requires a direct conversation for payback modeling.';
      if (totalValue > 0 && totalPlatformCost > 0) {
        const paybackMonths = totalPlatformCost / totalValue;
        paybackText = `Estimated payback period: ${paybackMonths.toFixed(1)} months.`;
      }

      document.getElementById('metricRecoveredLeads').textContent = recoveredLeads.toFixed(0);
      document.getElementById('metricNewCustomers').textContent = newCustomers.toFixed(0);
      document.getElementById('metricAddedRevenue').textContent = formatCurrency(addedRevenue);
      document.getElementById('metricSavedValue').textContent = formatCurrency(savedValue);
      document.getElementById('metricROI').textContent = `${roiPct.toFixed(0)}%`;
      document.getElementById('metricPayback').textContent =
        `${paybackText} Estimated monthly platform cost: ${formatCurrency(totalPlatformCost)}.`;
    }
  </script>
</body>
